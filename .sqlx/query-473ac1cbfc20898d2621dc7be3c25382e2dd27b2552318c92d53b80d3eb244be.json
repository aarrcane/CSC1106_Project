  "query": "SELECT s.id AS student_id, u.display_name, u.email\n           FROM enrollments e\n           JOIN students s ON s.id = e.student_id\n           JOIN users u ON u.id = s.user_id\n           WHERE e.course_id = $1\n           ORDER BY u.display_name ASC",

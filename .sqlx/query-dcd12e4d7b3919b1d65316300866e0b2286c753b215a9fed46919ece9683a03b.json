{
  "db_name": "PostgreSQL",
  "query": "SELECT\n            a.id,\n            a.course_id,\n            c.course_code,\n            c.course_name,\n            a.week_number,\n            a.title,\n            a.description,\n            a.due_date,\n            a.max_score,\n            COUNT(af.id) AS file_count\n           FROM assignments a\n           JOIN courses c ON c.id = a.course_id\n           LEFT JOIN assignment_files af ON af.assignment_id = a.id\n           WHERE a.course_id = $1\n           GROUP BY a.id, c.course_code, c.course_name\n           ORDER BY a.week_number NULLS LAST, a.due_date",

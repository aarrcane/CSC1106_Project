# Shared Supabase cloud database example.
# Use the Session Pooler connection string from Supabase, then add sslmode=require.
DATABASE_URL=postgres://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
SESSION_SECRET=replace-this-with-a-64-character-random-secret-for-local-dev-1234567890

# Local PostgreSQL alternative:
# DATABASE_URL=postgres://postgres:PASSWORD_HERE@localhost:5433/lms_db
